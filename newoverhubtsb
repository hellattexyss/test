-- 1) Strict WindUI loader with logs
local URLs={
  "https://github.com/Footagesus/WindUI/releases/latest/download/main.lua",
  "https://ghproxy.com/https://github.com/Footagesus/WindUI/releases/latest/download/main.lua",
  "https://download.fastgit.org/Footagesus/WindUI/releases/latest/download/main.lua"
}
getgenv().WindUI_Cache=getgenv().WindUI_Cache or nil
local function log(...) print("[WindUI]", ...) end
local function loadWind()
  if getgenv().WindUI_Cache then
    log("Using cached build")
    local f,lferr=loadstring(getgenv().WindUI_Cache)
    if not f then error("Cache loadstring failed: "..tostring(lferr)) end
    local ok,lib=pcall(f)
    if not ok then error("Cache executed with error: "..tostring(lib)) end
    if type(lib)~="table" then error("Cache returned non-table") end
    return lib
  end
  local lastErr
  for _,u in ipairs(URLs) do
    log("HttpGet ->",u)
    local ok,src=pcall(function() return game:HttpGet(u) end)
    if ok and type(src)=="string" and #src>100 then
      getgenv().WindUI_Cache=src
      local f,err=loadstring(src)
      if not f then lastErr="compile error: "..tostring(err) continue end
      local ok2,lib=pcall(f)
      if not ok2 then lastErr="exec error: "..tostring(lib) continue end
      if type(lib)~="table" then lastErr="returned not table" continue end
      log("Loaded WindUI release")
      return lib
    else
      lastErr=src or "HttpGet failed"
    end
  end
  error("WindUI release load failed: "..tostring(lastErr))
end

