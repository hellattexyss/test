-- WindUI core (assembled from src style: window->tabs->sections->controls)
local function WindUISrc()
  local API={}
  local CoreGui=game:GetService("CoreGui")

  local function newCorner(p,r) local c=Instance.new("UICorner",p) c.CornerRadius=UDim.new(0,r or 8) return c end
  local function tween(o,props) TweenService:Create(o,TweenInfo.new(0.12,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),props):Play() end

  function API:CreateWindow(cfg)
    local sg=Instance.new("ScreenGui") sg.Name="Overhub_AutoblockUI" sg.IgnoreGuiInset=true sg.ResetOnSpawn=false sg.Parent=CoreGui
    local root=Instance.new("Frame",sg) root.Size=cfg.Size or UDim2.new(0,420,0,300) root.Position=UDim2.new(0.5,-210,0.5,-150) root.AnchorPoint=Vector2.new(0.5,0.5)
    root.BackgroundColor3=Color3.fromRGB(18,18,20) root.BorderSizePixel=0 newCorner(root,12)
    local stroke=Instance.new("UIStroke",root) stroke.Thickness=1 stroke.Color=Color3.fromRGB(60,200,140) stroke.Transparency=0.2

    -- header
    local header=Instance.new("Frame",root) header.Size=UDim2.new(1,-14,0,34) header.Position=UDim2.new(0,7,0,7) header.BackgroundTransparency=1
    local title=Instance.new("TextLabel",header) title.Size=UDim2.new(1,0,1,0) title.BackgroundTransparency=1 title.Text=(cfg.Title or "Window").."  •  "..(cfg.SubTitle or "")
    title.Font=Enum.Font.GothamBold title.TextScaled=true title.TextXAlignment=Enum.TextXAlignment.Left title.TextColor3=Color3.fromRGB(255,255,255)

    -- columns
    local tabsCol=Instance.new("Frame",root) tabsCol.BackgroundTransparency=1 tabsCol.Size=UDim2.new(0,126,1,-48) tabsCol.Position=UDim2.new(0,7,0,41)
    local tabList=Instance.new("UIListLayout",tabsCol) tabList.Padding=UDim.new(0,6)
    local pageCol=Instance.new("Frame",root) pageCol.BackgroundTransparency=1 pageCol.Size=UDim2.new(1,-140,1,-48) pageCol.Position=UDim2.new(0,133,0,41)

    -- drag
    if cfg.Draggable~=false then
      local drag,st,sp=false,nil,nil
      root.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true st=i.Position sp=root.Position i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then drag=false end end) end end)
      UserInputService.InputChanged:Connect(function(i) if drag and i.UserInputType==Enum.UserInputType.MouseMovement then local d=i.Position-st root.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y) end end)
    end

    local onOpen,onClose
    function sg:Toggle(v) root.Visible=v if v and onOpen then onOpen() end if (not v) and onClose then onClose() end end
    local win={}
    function win:OnOpened(cb) onOpen=cb end
    function win:OnClosed(cb) onClose=cb end

    function win:CreateTab(opt)
      local tbtn=Instance.new("TextButton",tabsCol) tbtn.Size=UDim2.new(1,0,0,28) tbtn.Text=opt.Title or "Tab"
      tbtn.BackgroundColor3=Color3.fromRGB(30,30,32) tbtn.TextColor3=Color3.fromRGB(235,235,235) tbtn.Font=Enum.Font.GothamBold tbtn.TextScaled=true newCorner(tbtn,8)

      local page=Instance.new("ScrollingFrame",pageCol) page.Visible=false page.Size=UDim2.new(1,0,1,0) page.BackgroundTransparency=1
      page.ScrollBarThickness=6 page.ScrollBarImageColor3=Color3.fromRGB(80,220,160) page.CanvasSize=UDim2.new(0,0,0,0)
      local pl=Instance.new("UIListLayout",page) pl.Padding=UDim.new(0,8)
      tbtn.MouseButton1Click:Connect(function() for _,v in ipairs(pageCol:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible=false end end page.Visible=true end)
      if #pageCol:GetChildren()==0 then page.Visible=true end

      local tab={}
      function tab:CreateSection(sopt)
        local sec=Instance.new("Frame",page) sec.BackgroundTransparency=1 sec.Size=UDim2.new(1,-8,0,0) sec.AutomaticSize=Enum.AutomaticSize.Y
        local sl=Instance.new("UIListLayout",sec) sl.Padding=UDim.new(0,6)
        local head=Instance.new("TextLabel",sec) head.BackgroundTransparency=1 head.Text=sopt.Title or "" head.Font=Enum.Font.GothamBold head.TextScaled=true head.TextColor3=Color3.fromRGB(255,255,255)

        local apiS={}
        function apiS:AddParagraph(o)
          local l=Instance.new("TextLabel",sec) l.BackgroundTransparency=1 l.Font=Enum.Font.Gotham l.TextScaled=true l.TextXAlignment=Enum.TextXAlignment.Left l.TextColor3=Color3.fromRGB(235,235,235)
          l.Text=(o.Title or "").."\n"..(o.Content or "") return l
        end
        function apiS:AddButton(o)
          local b=Instance.new("TextButton",sec) b.Size=UDim2.new(1,0,0,28) b.Text=o.Title or "Button" b.BackgroundColor3=Color3.fromRGB(34,34,36) b.TextColor3=Color3.fromRGB(255,255,255) b.Font=Enum.Font.Gotham b.TextScaled=true newCorner(b,8)
          b.MouseButton1Click:Connect(function() if o.Callback then o.Callback() end end) return b
        end
        function apiS:AddToggle(o)
          local f=Instance.new("TextButton",sec) f.Size=UDim2.new(1,0,0,28) f.BackgroundColor3=Color3.fromRGB(34,34,36) f.TextScaled=true f.Font=Enum.Font.GothamBold newCorner(f,8)
          local st=o.Default and true or false
          local function paint()
            f.Text=(st and "ON  " or "OFF ")..(o.Title or "Toggle")
            f.TextColor3= st and Color3.fromRGB(140,255,200) or Color3.fromRGB(255,255,255)
            tween(f,{BackgroundColor3=st and Color3.fromRGB(0,170,110) or Color3.fromRGB(34,34,36)})
          end
          paint()
          f.MouseButton1Click:Connect(function() st=not st paint() if o.Callback then o.Callback(st) end end)
          return { OnChanged=function(cb) f.MouseButton1Click:Connect(function() cb(st) end) end, Set=function(v) st=v paint() end }
        end
        function apiS:AddInput(o)
          local l=Instance.new("TextLabel",sec) l.BackgroundTransparency=1 l.Text=o.Title or "" l.Font=Enum.Font.Gotham l.TextScaled=true l.TextXAlignment=Enum.TextXAlignment.Left l.TextColor3=Color3.fromRGB(235,235,235)
          local b=Instance.new("TextBox",sec) b.Size=UDim2.new(1,0,0,26) b.Text=o.Default or "" b.PlaceholderText=o.Placeholder or "" b.BackgroundColor3=Color3.fromRGB(34,34,36) b.TextColor3=Color3.fromRGB(255,255,255) b.Font=Enum.Font.Gotham b.TextScaled=true newCorner(b,8)
          b.FocusLost:Connect(function() if o.Callback then o.Callback(b.Text) end end) return b
        end
        function apiS:AddSlider(o)
          local l=Instance.new("TextLabel",sec) l.BackgroundTransparency=1 l.Text=(o.Title or "Slider")..": "..tostring(o.Default or o.Min) l.Font=Enum.Font.Gotham l.TextScaled=true l.TextXAlignment=Enum.TextXAlignment.Left l.TextColor3=Color3.fromRGB(235,235,235)
          local bar=Instance.new("Frame",sec) bar.Size=UDim2.new(1,0,0,8) bar.BackgroundColor3=Color3.fromRGB(42,42,46) newCorner(bar,4)
          local fill=Instance.new("Frame",bar) fill.Size=UDim2.new(0,0,1,0) fill.BackgroundColor3=Color3.fromRGB(60,200,140) newCorner(fill,4)
          local val=o.Default or o.Min
          local function setv(n) n=math.clamp(n,o.Min,o.Max) val=n l.Text=(o.Title or "Slider")..": "..tostring(val) fill.Size=UDim2.new((val-o.Min)/(o.Max-o.Min),0,1,0) if o.Callback then o.Callback(val) end end
          setv(val)
          bar.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            local mouse=UserInputService:GetMouseLocation() local rel=(mouse.X-bar.AbsolutePosition.X)/bar.AbsoluteSize.X setv(o.Min + rel*(o.Max-o.Min)) end end)
          return { Set=function(n) setv(n) end }
        end
        return apiS
      end
      return tab
    end
    return win
  end
  return API
end

