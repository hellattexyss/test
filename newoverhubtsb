-- 4) Build UI (wrap each section in pcall to catch any runtime error that would stop rendering)
local function safe(fn,tag) local ok,err=pcall(fn) if not ok then warn("[OverHub UI error@"..tag.."] "..tostring(err)) end end

local Window
