-- Live blur on open/close
local cam=workspace.CurrentCamera
local Blur=Instance.new("BlurEffect") Blur.Enabled=false Blur.Size=0 Blur.Parent=cam
local function setBlur(on)
    if on then
        Blur.Enabled=true
        TweenService:Create(Blur,TweenInfo.new(0.22,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Size=18}):Play()
    else
        TweenService:Create(Blur,TweenInfo.new(0.22,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Size=0}):Play()
        task.delay(0.24,function() if Blur then Blur.Enabled=false end end)
    end
end

