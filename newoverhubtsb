-- Auto Counter action
local function counterFire()
  local ch=LP.Character if not ch then return end
  local comm=ch:FindFirstChild("Communicate") if not comm then return end
  local prey=LP.Backpack and LP.Backpack:FindFirstChild("Prey's Peril")
  if prey then comm:FireServer({Tool=prey,Goal="Console Move"}) end
  local split=LP.Backpack and LP.Backpack:FindFirstChild("Split Second Counter")
  if split then comm:FireServer({Tool=split,Goal="Console Move"}) end
end

-- Helpers
local function myHRP() local ch=LP.Character if not ch then return nil end return ch:FindFirstChild("HumanoidRootPart") end

-- Autoblock logic pieces from previous version, dash-safe gate added
local function autoblockAllowed()
  -- inhibit during and shortly after dash
  local cd=S.dashBlockCooldown and S.dashBlockCooldown() or 0.25
  if os.clock()-lastDashAt < cd then return false end
  return S.detectActive and S.detectActive() or false
end

-- Existing animation-based block detection (trimmed: keep core)
local function scanAndBlock()
  if not autoblockAllowed() then return end
  local my=myHRP() if not my then return end
  -- scan Live or players
  local live=workspace:FindFirstChild("Live")
  local function eachTargets(cb)
    if live then for _,m in ipairs(live:GetChildren()) do cb(m) end
    else for _,p in ipairs(Players:GetPlayers()) do if p~=LP and p.Character then cb(p.Character) end end end
  end
  eachTargets(function(char)
    local hrp=char:FindFirstChild("HumanoidRootPart")
    local hum=char:FindFirstChildWhichIsA("Humanoid")
    local an=hum and hum:FindFirstChildOfClass("Animator")
    if not (hrp and hum and an) then return end
    local dist=(hrp.Position-my.Position).Magnitude
    local nR=S.normalRange and S.normalRange() or 1
    local sR=S.specialRange and S.specialRange() or 50
    local kR=S.skillRange and S.skillRange() or 50
    local kHold=S.skillDelay and S.skillDelay() or 1.2

    local playing={} for _,tr in ipairs(an:GetPlayingAnimationTracks()) do
      local raw=tr.Animation and tr.Animation.AnimationId
      if raw then playing[raw]=true end
    end

    -- Normal block window
    local normalHit=false
    for id,_ in pairs(playing) do if normal[id] then normalHit=true break end end
    if normalHit and dist<=nR then
      fireRemote("KeyPress"); task.wait(0.15); fireRemote("KeyRelease")
      if S.m1After and S.m1After() then
        -- doAfter kept as release burst
        fireRemote("Communicate",true)
        task.delay(0.2,function() fireRemote("LeftClickRelease",true) end)
      end
      return
    end

    -- Specials
    local specialHit=false
    for id,_ in pairs(playing) do if delayed[id] then specialHit=true break end end
    if specialHit and dist<=sR and not (S.m1Catch and S.m1Catch()) then
      fireRemote("KeyPress"); task.delay(1,function() fireRemote("KeyRelease") end)
      return
    end

    -- Skills (hold)
    local anySkill=false
    for id,_ in pairs(playing) do if normal[id] and not delayed[id] then anySkill=true break end end
    if anySkill and dist<=kR then
      fireRemote("KeyPress"); task.delay(kHold,function() fireRemote("KeyRelease") end)
      return
    end
  end)
end

-- Auto Counter loop
local function autoCounterTick()
  if not (S.autoCounter and S.autoCounter()) then return end
  local my=myHRP() if not my then return end
  local rng=S.counterRange and S.counterRange() or 13
  local live=workspace:FindFirstChild("Live")
  local targets=live and live:GetChildren() or {}
  if not live then for _,p in ipairs(Players:GetPlayers()) do if p~=LP and p.Character then table.insert(targets,p.Character) end end end
  for _,char in ipairs(targets) do
    local hrp=char and char:FindFirstChild("HumanoidRootPart")
    local hum=char and char:FindFirstChildWhichIsA("Humanoid")
    local an=hum and hum:FindFirstChildOfClass("Animator")
    if hrp and hum and an then
      local d=(hrp.Position-my.Position).Magnitude
      if d<=rng then
        for _,tr in ipairs(an:GetPlayingAnimationTracks()) do
          local id=tr.Animation and tr.Animation.AnimationId
          if id and (normal[id] or delayed[id]) then
            local key=tostring(char:GetDebugId())..id
            if not activated[key] then
              activated[key]=true
              if delayed[id] then task.delay(0.05,counterFire) else counterFire() end
            end
          end
        end
      end
    end
  end
end

-- No Endlag integration: respect SAVE.noEndlag; ported core gating
do
  local UIS=game:GetService("UserInputService")
  local lastDash=0
  UIS.InputBegan:Connect(function(input,processed)
    if processed then return end
    if input.KeyCode==Enum.KeyCode.Q then
      lastDash=os.clock(); if S.noEndlag and not S.noEndlag() then return end
      -- prefer forward dash: only if not pressing A/S/D (kept logic simple)
      if not (UIS:IsKeyDown(Enum.KeyCode.A) or UIS:IsKeyDown(Enum.KeyCode.S) or UIS:IsKeyDown(Enum.KeyCode.D)) then
        fireRemote("KeyPress") -- simulate small unblock if needed
      end
    end
  end)
end

-- ESP camlock remains from previous version if present (not included here to keep size)

-- Heartbeat loops
RunService.Heartbeat:Connect(function()
  pcall(scanAndBlock)
  pcall(autoCounterTick)
end)
