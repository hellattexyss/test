      for _,ins in ipairs(Lighting:GetChildren()) do if ins:IsA("PostEffect") then ins.Enabled=false end end
      for _,d in ipairs(workspace:GetDescendants()) do
        if d:IsA("ParticleEmitter") or d:IsA("Trail") then d.Enabled=false end
        if d:IsA("BasePart") then d.CastShadow=false end
      end
    else
      for _,ins in ipairs(Lighting:GetChildren()) do if ins:IsA("PostEffect") then ins.Enabled=true end end
      for _,d in ipairs(workspace:GetDescendants()) do
        if d:IsA("ParticleEmitter") or d:IsA("Trail") then d.Enabled=true end
        if d:IsA("BasePart") then d.CastShadow=true end
      end
    end
  end)
end
