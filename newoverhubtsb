local function scanAndBlock()
  if not autoblockAllowed() then return end
  local my=myHRP() if not my then return end
  local live=workspace:FindFirstChild("Live")
  local targets=live and live:GetChildren() or {}
  if not live then for _,p in ipairs(Players:GetPlayers()) do if p~=LP and p.Character then table.insert(targets,p.Character) end end end

  for _,char in ipairs(targets) do
    local hrp=char:FindFirstChild("HumanoidRootPart")
    local hum=char:FindFirstChildWhichIsA("Humanoid")
    local an=hum and hum:FindFirstChildOfClass("Animator")
    if hrp and hum and an then
      local dist=(hrp.Position-my.Position).Magnitude
      local nR=S.normalRange and S.normalRange() or 1
      local sR=S.specialRange and S.specialRange() or 50
      local kR=S.skillRange and S.skillRange() or 50
      local kHold=S.skillDelay and S.skillDelay() or 1.2

      local playing={} for _,tr in ipairs(an:GetPlayingAnimationTracks()) do local raw=tr.Animation and tr.Animation.AnimationId if raw then playing[raw]=true end end

      -- Prioritize specials first, then normals, then skills
      local special=false for id,_ in pairs(playing) do if delayed[id] then special=true break end end
      if special and dist<=sR and not (S.m1Catch and S.m1Catch()) then fireRemote("KeyPress"); task.delay(1,function() fireRemote("KeyRelease") end) return end

      local normalHit=false for id,_ in pairs(playing) do if normal[id] and not delayed[id] then normalHit=true break end end
      if normalHit and dist<=nR then fireRemote("KeyPress"); task.wait(0.12); fireRemote("KeyRelease")
        if S.m1After and S.m1After() then fireRemote("Communicate",true) task.delay(0.2,function() fireRemote("LeftClickRelease",true) end) end
        return
      end

      local anySkill=normalHit -- reuse merged list for skill timing
      if anySkill and dist<=kR then fireRemote("KeyPress"); task.delay(kHold,function() fireRemote("KeyRelease") end) return end
    end
  end
end

-- Auto Counter loop
local function autoCounterTick()
  if not (S.autoCounter and S.autoCounter()) then return end
  local my=myHRP() if not my then return end
  local rng=S.counterRange and S.counterRange() or 13
  local live=workspace:FindFirstChild("Live")
  local targets=live and live:GetChildren() or {}
  if not live then for _,p in ipairs(Players:GetPlayers()) do if p~=LP and p.Character then table.insert(targets,p.Character) end end end
  for _,char in ipairs(targets) do
    local hrp=char and char:FindFirstChild("HumanoidRootPart")
    local hum=char and char:FindFirstChildWhichIsA("Humanoid")
    local an=hum and hum:FindFirstChildOfClass("Animator")
    if hrp and hum and an then
      local d=(hrp.Position-my.Position).Magnitude
      if d<=rng then
        for _,tr in ipairs(an:GetPlayingAnimationTracks()) do
          local id=tr.Animation and tr.Animation.AnimationId
          if id and (normal[id] or delayed[id]) then
            local key=tostring(char:GetDebugId())..id
            if not activated[key] then
              activated[key]=true
              if delayed[id] then task.delay(0.05,counterFire) else counterFire() end
            end
          end
        end
      end
    end
  end
end

-- Working No Endlag (M1 Reset) minimal hook: only allows forward dash if feature enabled and state not blocked
local function noEndlagBind()
  if not (S.noEndlag and S.noEndlag()) then return end
  UserInputService.InputBegan:Connect(function(input,processed)
    if processed then return end
    if input.KeyCode==Enum.KeyCode.Q then
      -- forward-only: not pressing A/S/D
      if not (UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.S) or UserInputService:IsKeyDown(Enum.KeyCode.D)) then
        -- Trigger a quick dash command via Communicate if available
        local ch=myChar() local comm=ch and ch:FindFirstChild("Communicate")
        if comm then task.defer(function() comm:FireServer({Dash=Enum.KeyCode.W, Key=Enum.KeyCode.Q, Goal="KeyPress"}) end) end
      end
    end
  end)
end
task.defer(noEndlagBind)

-- Track own left-click usage to mute autoblock briefly
UserInputService.InputBegan:Connect(function(input)
  if input.UserInputType==Enum.UserInputType.MouseButton1 then
    leftClickActive=true; lastOwnM1At=os.clock()
  end
end)
UserInputService.InputEnded:Connect(function(input)
  if input.UserInputType==Enum.UserInputType.MouseButton1 then
    leftClickActive=false
  end
end)

RunService.Heartbeat:Connect(function()
  pcall(scanAndBlock)
  pcall(autoCounterTick)
end)
