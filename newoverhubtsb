-- FPS boost controller (callable)
_G.__OverhubFPS=function(enabled)
  local ok,err=pcall(function()
    if enabled then
      settings().Rendering.QualityLevel=Enum.QualityLevel.Level01
      settings().Rendering.MeshPartDetailLevel=Enum.MeshPartDetailLevel.Level01
      workspace.StreamingEnabled=true
      workspace.StreamingMinRadius=32
      workspace.StreamingTargetRadius=64
      workspace.GlobalWind=Vector3.new()
      if workspace:FindFirstChildOfClass("Terrain") then workspace.Terrain.WaterWaveSize=0 workspace.Terrain.WaterWaveSpeed=0 workspace.Terrain.Decoration=false end
      local Debris=game:GetService("Debris")
      for _,ins in ipairs(Lighting:GetChildren()) do if ins:IsA("BloomEffect") or ins:IsA("SunRaysEffect") or ins:IsA("DepthOfFieldEffect") or ins:IsA("ColorCorrectionEffect") then ins.Enabled=false end end
      for _,d in ipairs(workspace:GetDescendants()) do
        if d:IsA("ParticleEmitter") or d:IsA("Trail") then d.Enabled=false end
        if d:IsA("PostEffect") then d.Enabled=false end
        if d:IsA("BasePart") then d.CastShadow=false end
      end
    else
      -- light restore (do not touch game’s own settings too much)
      for _,ins in ipairs(Lighting:GetChildren()) do if ins:IsA("PostEffect") then ins.Enabled=true end end
      for _,d in ipairs(workspace:GetDescendants()) do
        if d:IsA("ParticleEmitter") or d:IsA("Trail") then d.Enabled=true end
        if d:IsA("BasePart") then d.CastShadow=true end
      end
    end
  end)
end
_G.__OverhubFPS(SAVE.fpsBoost)
