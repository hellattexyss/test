  page.ScrollBarThickness=6 page.ScrollBarImageColor3=Color3.fromRGB(80,220,160) local lay=Instance.new("UIListLayout",page) lay.Padding=UDim.new(0,8)
  btn.MouseButton1Click:Connect(function() for _,v in ipairs(Pages:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible=false end end page.Visible=true end)
  if #Pages:GetChildren()==0 then page.Visible=true end
  local function section(title)
    local frame=Instance.new("Frame",page) frame.BackgroundTransparency=1 frame.Size=UDim2.new(1,-8,0,0) frame.AutomaticSize=Enum.AutomaticSize.Y
    local sl=Instance.new("UIListLayout",frame) sl.Padding=UDim.new(0,6)
    local head=Instance.new("TextLabel",frame) head.BackgroundTransparency=1 head.Text=title head.Font=Enum.Font.GothamBold head.TextScaled=true head.TextColor3=Color3.fromRGB(255,255,255)
    local api={}
    function api:Paragraph(t,c) local l=Instance.new("TextLabel",frame) l.BackgroundTransparency=1 l.Text=(t or "").."\n"..(c or "") l.Font=Enum.Font.Gotham l.TextScaled=true l.TextXAlignment=Enum.TextXAlignment.Left l.TextColor3=Color3.fromRGB(235,235,235) return l end
    function api:Button(text,cb) local b=Instance.new("TextButton",frame) b.Size=UDim2.new(1,0,0,28) b.Text=text b.BackgroundColor3=Color3.fromRGB(34,34,34) b.TextColor3=Color3.fromRGB(255,255,255) b.Font=Enum.Font.Gotham b.TextScaled=true Instance.new("UICorner",b).CornerRadius=UDim.new(0,8) b.MouseButton1Click:Connect(cb) return b end
    function api:Toggle(text,default,cb)
      local f=Instance.new("TextButton",frame) f.Size=UDim2.new(1,0,0,28) f.BackgroundColor3=Color3.fromRGB(34,34,34) f.TextScaled=true f.Font=Enum.Font.GothamBold Instance.new("UICorner",f).CornerRadius=UDim.new(0,8)
      local state=default and true or false
      local function paint()
        f.Text=(state and "ON  " or "OFF ")..text
        f.TextColor3= state and Color3.fromRGB(140,255,200) or Color3.fromRGB(255,255,255)
        TweenService:Create(f,TweenInfo.new(0.12,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{BackgroundColor3= state and Color3.fromRGB(0,170,110) or Color3.fromRGB(34,34,34)}):Play()
      end
      paint()
      f.MouseButton1Click:Connect(function() state=not state paint() if cb then cb(state) end end)
      return {Set=function(v) state=v paint() end, OnChanged=function(cb2) f.MouseButton1Click:Connect(function() cb2(state) end) end}
    end
    function api:Input(text,default,cb)
      local l=Instance.new("TextLabel",frame) l.BackgroundTransparency=1 l.Text=text l.Font=Enum.Font.Gotham l.TextScaled=true l.TextXAlignment=Enum.TextXAlignment.Left l.TextColor3=Color3.fromRGB(235,235,235)
      local b=Instance.new("TextBox",frame) b.Size=UDim2.new(1,0,0,26) b.Text=default or "" b.BackgroundColor3=Color3.fromRGB(34,34,34) b.TextColor3=Color3.fromRGB(255,255,255) b.Font=Enum.Font.Gotham b.TextScaled=true Instance.new("UICorner",b).CornerRadius=UDim.new(0,8)
      b.FocusLost:Connect(function() if cb then cb(b.Text) end end)
      return b
    end
    function api:Slider(text,min,max,default,cb)
      local l=Instance.new("TextLabel",frame) l.BackgroundTransparency=1 l.Text=text..": "..tostring(default) l.Font=Enum.Font.Gotham l.TextScaled=true l.TextXAlignment=Enum.TextXAlignment.Left l.TextColor3=Color3.fromRGB(235,235,235)
      local bar=Instance.new("Frame",frame) bar.Size=UDim2.new(1,0,0,8) bar.BackgroundColor3=Color3.fromRGB(40,40,40) Instance.new("UICorner",bar).CornerRadius=UDim.new(0,4)
      local fill=Instance.new("Frame",bar) fill.Size=UDim2.new(0,0,1,0) fill.BackgroundColor3=Color3.fromRGB(60,200,140) Instance.new("UICorner",fill).CornerRadius=UDim.new(0,4)
      local val=default
      local function setv(n) n=math.clamp(n,min,max) val=n l.Text=text..": "..tostring(val) fill.Size=UDim2.new((val-min)/(max-min),0,1,0) if cb then cb(val) end end
      setv(default)
      bar.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
          local mouse=UserInputService:GetMouseLocation()
          local rel=(mouse.X-bar.AbsolutePosition.X)/bar.AbsoluteSize.X setv(min + rel*(max-min))
        end
      end)
      return {Set=function(n) setv(n) end}
    end
    return api
  end
  return btn,page,section
end

