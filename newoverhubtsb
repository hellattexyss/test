-- Animated toggle function: bg and text color tween
local function applyToggleVisual(btn,isOn)
  btn.Text=isOn and "ON" or "OFF"
  local toBG=isOn and Color3.fromRGB(0,170,110) or Color3.fromRGB(26,60,44)
  local toTX=isOn and Color3.fromRGB(140,255,200) or Color3.fromRGB(255,255,255)
  TweenService:Create(btn,TweenInfo.new(0.12,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{BackgroundColor3=toBG}):Play()
  TweenService:Create(btn.TextLabel or btn,TweenInfo.new(0.12,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{TextColor3=toTX}):Play()
end
local function setT(btn,on) applyToggleVisual(btn,on) end

