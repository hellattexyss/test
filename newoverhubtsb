local function addToggle(section,label,key,tip)
  return section:AddToggle({Title=label,Description=tip or "",Default=SAVE[key]==true,Callback=function(v) SAVE[key]=v persist() end})
end
local function addInput(section,label,key,ph)
  section:AddInput({Title=label,Placeholder=ph or "",Default=tostring(SAVE[key]),Numeric=true,Callback=function(txt)local n=tonumber(txt) if n then SAVE[key]=n persist() end end})
end
local function addSlider(section,label,key,min,max,step)
  section:AddSlider({Title=label,Min=min,Max=max,Default=SAVE[key],Increment=step or 1,Rounding=0,Callback=function(n) SAVE[key]=n persist() end})
end
local function addButton(section,label,cb) section:AddButton({Title=label,Callback=cb}) end
local function addParagraph(section,title,content) return section:AddParagraph({Title=title,Content=content}) end

