-- Common helpers
local function myChar() return LP.Character end
local function myHRP() local c=myChar() return c and c:FindFirstChild("HumanoidRootPart") end
local function fireRemote(goal,mobile)
  local args={{Goal=goal,Key=(goal=="KeyPress" or goal=="KeyRelease") and Enum.KeyCode.F or nil,Mobile=mobile or nil}}
  local ch=myChar() if not ch then return end
  local c=ch:FindFirstChild("Communicate") if c then c:FireServer(unpack(args)) end
end

-- Gates
local lastDashAt=0
local lastOwnM1At=0
local leftClickActive=false

UserInputService.InputBegan:Connect(function(input,processed)
  if processed then return end
  if input.KeyCode==Enum.KeyCode.Q then lastDashAt=os.clock() end
  if input.UserInputType==Enum.UserInputType.MouseButton1 then leftClickActive=true lastOwnM1At=os.clock() end
end)
UserInputService.InputEnded:Connect(function(input)
  if input.UserInputType==Enum.UserInputType.MouseButton1 then leftClickActive=false end
end)

-- Observe self animations to mark M1 window
local function observeSelf()
  local c=myChar() if not c then return end
  local hum=c:FindFirstChildOfClass("Humanoid")
  local an=hum and hum:FindFirstChildOfClass("Animator")
  if an then
    an.AnimationPlayed:Connect(function(track) lastOwnM1At=os.clock() end)
  end
end
task.defer(observeSelf)
LP.CharacterAdded:Connect(function() task.wait(0.2) observeSelf() end)

