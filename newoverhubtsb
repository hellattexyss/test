local function myChar() return LP.Character end
local function myHRP() local c=myChar() return c and c:FindFirstChild("HumanoidRootPart") end
local function fireRemote(goal,mobile)
  local args={{Goal=goal,Key=(goal=="KeyPress" or goal=="KeyRelease") and Enum.KeyCode.F or nil,Mobile=mobile or nil}}
  local ch=myChar() if not ch then return end
  local c=ch:FindFirstChild("Communicate") if c then c:FireServer(unpack(args)) end
end

local lastDashAt=0
local lastOwnM1At=0
local leftClickActive=false
UserInputService.InputBegan:Connect(function(input,processed)
  if processed then return end
  if input.KeyCode==Enum.KeyCode.Q then lastDashAt=os.clock() end
  if input.UserInputType==Enum.UserInputType.MouseButton1 then leftClickActive=true lastOwnM1At=os.clock() end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 then leftClickActive=false end end)

local function autoblockAllowed()
  if not (S.detectActive and S.detectActive()) then return false end
  local now=os.clock()
  if (now-lastDashAt) < (S.dashBlockCooldown() or 0.25) then return false end
  if (now-lastOwnM1At) < (S.m1BlockCooldown() or 0.25) then return false end
  if leftClickActive then return false end
  return true
end

