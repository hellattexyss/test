-- Helper for animated WindUI toggles persisting
local function addToggle(section,label,key,tip)
    return section:AddToggle({
        Title=label,
        Description=tip or "",
        Default=SAVE[key]==true,
        Callback=function(v) SAVE[key]=v persist() end
    })
end
local function addBox(section,label,key,ph)
    return section:AddInput({
        Title=label, Placeholder=ph or "", Default=tostring(SAVE[key]),
        Numeric=true, Callback=function(txt) local n=tonumber(txt) if n then SAVE[key]=n persist() end end
    })
end
local function addSlider(section,label,key,min,max,step)
    return section:AddSlider({
        Title=label, Min=min, Max=max, Default=SAVE[key], Rounding=0, Callback=function(n) SAVE[key]=n persist() end, Increment=step or 1
    })
end
local function addButton(section,label,cb)
    return section:AddButton({Title=label, Callback=cb})
end

