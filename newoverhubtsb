-- Dual loader: try Source.lua, else use embedded minimal build (no example/demo)
local function loadWindDual()
    local lib
    local ok,err=pcall(function()
        lib=loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/refs/heads/main/Source.lua"))()
    end)
    if not ok or type(lib)~="table" then
        -- Embedded tiny WindUI shell: CreateWindow/Tabs/Sections + basic controls
        lib = (function()
            local api={}
            local UIS=game:GetService("UserInputService")
            local CoreGui=game:GetService("CoreGui")
            function api:CreateWindow(cfg)
                local sg=Instance.new("ScreenGui",CoreGui) sg.IgnoreGuiInset=true sg.ResetOnSpawn=false sg.Name="WindUI_Fallback"
                local root=Instance.new("Frame",sg) root.Size=cfg.Size or UDim2.new(0,420,0,300) root.Position=UDim2.new(0.5,-210,0.5,-150) root.AnchorPoint=Vector2.new(0.5,0.5)
                root.BackgroundColor3=Color3.fromRGB(24,24,24) root.BorderSizePixel=0
                local c=Instance.new("UICorner",root) c.CornerRadius=UDim.new(0,10)
                local title=Instance.new("TextLabel",root) title.Size=UDim2.new(1,0,0,30) title.BackgroundTransparency=1 title.Text=(cfg.Title or "Window").."  "..(cfg.SubTitle or "")
                title.Font=Enum.Font.GothamBold title.TextScaled=true title.TextColor3=Color3.fromRGB(255,255,255)
                local tabsBar=Instance.new("Frame",root) tabsBar.BackgroundTransparency=1 tabsBar.Size=UDim2.new(0,120,1,-30) tabsBar.Position=UDim2.new(0,0,0,30)
                local pages=Instance.new("Frame",root) pages.BackgroundTransparency=1 pages.Size=UDim2.new(1,-120,1,-30) pages.Position=UDim2.new(0,120,0,30)
                local currentOpen=true local onOpen,onClose=nil,nil
                function sg:Toggle(v) root.Visible=v currentOpen=v if v and onOpen then onOpen() end if (not v) and onClose then onClose() end end
                -- drag
                do local dragging=false local st,nilPos local sp
                    root.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true st=i.Position sp=root.Position i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then dragging=false end end) end end)
                    UIS.InputChanged:Connect(function(i) if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then local d=i.Position-st root.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y) end end)
                end
                local win={}
                function win:OnOpened(cb) onOpen=cb end
                function win:OnClosed(cb) onClose=cb end
                function win:CreateTab(opt)
                    local btn=Instance.new("TextButton",tabsBar) btn.Size=UDim2.new(1,0,0,28) btn.Text=opt.Title or "Tab"
                    btn.Font=Enum.Font.GothamBold btn.TextScaled=true btn.BackgroundTransparency=1 btn.TextColor3=Color3.fromRGB(220,220,220)
                    local page=Instance.new("Frame",pages) page.Visible=false page.Size=UDim2.new(1,0,1,0) page.BackgroundTransparency=1
                    btn.MouseButton1Click:Connect(function() for _,v in ipairs(pages:GetChildren()) do if v:IsA("Frame") then v.Visible=false end end page.Visible=true end)
                    if #pages:GetChildren()==1 then page.Visible=true end
                    local tab={}
                    function tab:CreateSection(s)
                        local holder=Instance.new("Frame",page) holder.BackgroundTransparency=1 holder.Size=UDim2.new(1,-10,0,0) holder.AutomaticSize=Enum.AutomaticSize.Y
                        local layout=Instance.new("UIListLayout",holder) layout.Padding=UDim.new(0,6)
                        function holder:_add(f) f.Parent=holder return f end
                        local sec={}
                        function sec:AddToggle(o)
                            local f=Instance.new("TextButton") f.Size=UDim2.new(1,0,0,28) f.Text=((o.Default and "[ON] " or "[OFF] ")..o.Title) f.BackgroundColor3=Color3.fromRGB(34,34,34) f.TextColor3=Color3.fromRGB(o.Default and 140 or 255,255,o.Default and 200 or 255) f.Font=Enum.Font.GothamBold f.TextScaled=true
                            local state=o.Default and true or false
                            f.MouseButton1Click:Connect(function() state=not state f.Text=(state and "[ON] " or "[OFF] ")..o.Title f.TextColor3=state and Color3.fromRGB(140,255,200) or Color3.fromRGB(255,255,255) if o.Callback then o.Callback(state) end end)
                            holder:_add(f)
                            return { OnChanged=function(cb) f.MouseButton1Click:Connect(function() cb(state) end) end }
                        end
                        function sec:AddInput(o)
                            local f=Instance.new("TextBox") f.Size=UDim2.new(1,0,0,26) f.Text=o.Default or "" f.PlaceholderText=o.Placeholder or "" f.BackgroundColor3=Color3.fromRGB(34,34,34) f.TextColor3=Color3.fromRGB(255,255,255) f.Font=Enum.Font.Gotham f.TextScaled=true holder:_add(f)
                            f.FocusLost:Connect(function() if o.Callback then o.Callback(f.Text) end end)
                            return f
                        end
                        function sec:AddSlider(o)
                            local f=Instance.new("TextLabel") f.Size=UDim2.new(1,0,0,26) f.BackgroundTransparency=1 f.Text=(o.Title..": "..tostring(o.Default)) f.Font=Enum.Font.Gotham f.TextScaled=true f.TextColor3=Color3.fromRGB(230,230,230) holder:_add(f)
                            local val=o.Default
                            -- simple arrows
                            local left=Instance.new("TextButton",holder) left.Size=UDim2.new(0.5,-3,0,24) left.Text="-" left.BackgroundColor3=Color3.fromRGB(34,34,34) left.TextScaled=true
                            local right=Instance.new("TextButton",holder) right.Size=UDim2.new(0.5,-3,0,24) right.Position=UDim2.new(0.5,6,0,0) right.Text="+" right.BackgroundColor3=Color3.fromRGB(34,34,34) right.TextScaled=true
                            local function set(n) n=math.clamp(n,o.Min,o.Max) val=n f.Text=(o.Title..": "..tostring(val)) if o.Callback then o.Callback(val) end end
                            left.MouseButton1Click:Connect(function() set(val-(o.Increment or 1)) end)
                            right.MouseButton1Click:Connect(function() set(val+(o.Increment or 1)) end)
                            return { Set=function(n) set(n) end }
                        end
                        function sec:AddButton(o)
                            local f=Instance.new("TextButton") f.Size=UDim2.new(1,0,0,26) f.Text=o.Title or "Button" f.BackgroundColor3=Color3.fromRGB(34,34,34) f.TextColor3=Color3.fromRGB(255,255,255) f.Font=Enum.Font.Gotham f.TextScaled=true holder:_add(f)
                            f.MouseButton1Click:Connect(function() if o.Callback then o.Callback() end end)
                            return f
                        end
                        function sec:AddParagraph(o)
                            local f=Instance.new("TextLabel") f.BackgroundTransparency=1 f.Font=Enum.Font.GothamBold f.TextScaled=true f.TextColor3=Color3.fromRGB(255,255,255) f.Text=(o.Title or "").."\n"..(o.Content or "") holder:_add(f) return f
                        end
                        return sec
                    end
                    return tab
                end
                return win
            end
            return api
        end)()
    end
    return lib
end
